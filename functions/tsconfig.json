{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "lib",
    "rootDir": "src",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"]
}
