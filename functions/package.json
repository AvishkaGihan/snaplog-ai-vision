{
  "name": "@snaplog/functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for SnapLog",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@snaplog/contracts": "*",
    "firebase-admin": "13.6.0",
    "firebase-functions": "7.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
